{
  "comment": "AWS ECS Fargate task definition template for rpdr-fantasy-league. Replace all <PLACEHOLDER> values before registering.",
  "family": "rpdr-fantasy-league",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",

  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskRole",

  "containerDefinitions": [
    {
      "name": "rpdr-fantasy-league",
      "image": "<ACCOUNT_ID>.dkr.ecr.<REGION>.amazonaws.com/rpdr-fantasy-league:latest",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],

      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "3000"
        },
        {
          "name": "CORS_ORIGIN",
          "value": "https://<YOUR_FRONTEND_DOMAIN>"
        }
      ],

      "secrets": [
        {
          "comment": "Store DATABASE_URL in AWS Secrets Manager or SSM Parameter Store and reference it here.",
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:rpdr-fantasy/DATABASE_URL"
        },
        {
          "name": "JWT_SECRET",
          "valueFrom": "arn:aws:secretsmanager:<REGION>:<ACCOUNT_ID>:secret:rpdr-fantasy/JWT_SECRET"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/rpdr-fantasy-league",
          "awslogs-region": "<REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      },

      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -qO- http://localhost:3000/health || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    }
  ]
}
